PORT=3000

# Grok / xAI
GROK_API_KEY=xai-your-api-key
GROK_MODEL=grok-3-latest
# Optional. Set this if you want the UI to estimate remaining context room.
GROK_CONTEXT_WINDOW=

# Google Sheets
# Use these two IDs for the two game timeline spreadsheet files.
DYNOZOIC_SHEET_ID=your-dynozoic-timeline-google-sheet-id
DYNOZOIC_SHEET_NAME=Timeline
DYNOZOIC_FEEDBACK_SHEET_NAME=Feedback
DYNOZOIC_TARGET_SHEET_NAME=WeeklyTargets
DYNOZOIC_PLAN_SHEET_NAME=WeeklyPlan
EAA_SHEET_ID=your-earth-atlantis-abyss-google-sheet-id
EAA_SHEET_NAME=Timeline
EAA_FEEDBACK_SHEET_NAME=Feedback
EAA_TARGET_SHEET_NAME=WeeklyTargets
EAA_PLAN_SHEET_NAME=WeeklyPlan
# Optional. Database tab is created in this project's spreadsheet.
DATABASE_PROJECT=dynozoic
DATABASE_CACHE_RETENTION_DAYS=30
DATABASE_AUDIT_RETENTION_DAYS=90
DUE_SOON_DAYS=3

# Optional fallback for older one-sheet setup.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Timeline
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Discord bot input and report output are optional.
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CLIENT_ID=your-discord-application-client-id
DISCORD_PUBLIC_KEY=your-discord-application-public-key
DISCORD_GUILD_ID=optional-test-server-id-for-instant-command-update
DISCORD_UPDATE_CHANNEL_ID=channel-id-that-accepts-work-updates
DISCORD_REPORT_CHANNEL_ID=channel-id-that-receives-daily-summary
DAILY_REPORT_TIME=21:00
DAILY_TASK_TIME=06:00
ENABLE_DISCORD_BOT=true

# Vercel Cron security. Use this as Bearer token or ?secret=...
CRON_SECRET=change-me-cron-secret

# Optional lightweight API auth for the web endpoint.
WEB_FORM_SECRET=change-me
